# Data files (too big for Git)
data/raw/*
data/clean/*
!data/raw/.gitkeep
!data/clean/.gitkeep

# Logs
logs/*
!logs/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/

# Virtual environments
venv/
env/
.venv/

# Secrets and configs
.env
*.env
config.ini

# OS files
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp